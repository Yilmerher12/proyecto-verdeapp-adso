# ==============================================================================
# ♻️ VerdeApp — Variables de Entorno del Backend (Plantilla)
# ==============================================================================
# ¿Qué? Plantilla con TODAS las variables de entorno que necesita el backend.
# ¿Para qué? Guiar al equipo de desarrollo sobre qué variables configurar sin exponer datos reales.
# ¿Impacto? Sin este archivo, el sistema no podrá conectarse a la Base de Datos ni firmar Tokens.
#
# INSTRUCCIONES:
# 1. Copiar este archivo en la consola: cp .env.example .env
# 2. Si utiliza Docker Compose, NO necesita editar el archivo .env, Docker lo sobreescribe.
# 3. NUNCA versionar el archivo .env en git (.gitignore ya lo protege).

# ────────────────────────────
# 🗄️ Base de datos (PostgreSQL 17)
# ────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
# (Este valor es para ejecución local sin Docker. Docker inyectará el host "verde_db")
DATABASE_URL=postgresql://verde_user:verde_password@verde_db:5432/verdeapp_db
SMTP_HOST=verde_mailpit
# ────────────────────────────
# 🔐 JWT y Seguridad Criptográfica
# ────────────────────────────
# Clave secreta para firmar tokens JWT — Obligatorio cambiar en despliegue a producción
SECRET_KEY=9b8c2dfa8e34bc112a57f3de6c89fa0123de45fa67bc89de012345fa67bc89ab
ALGORITHM=HS256

# Duración de la sesión (Estándares de Seguridad OWASP)
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ────────────────────────────
# 📧 Servidor de Correos (Mailpit Local)
# ────────────────────────────
# Al usar Docker, Mailpit captura todos los correos en el puerto 8025.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# ────────────────────────────
# 🌐 Redes e Integración
# ────────────────────────────
# URL oficial del frontend (utilizada para políticas CORS y enlaces de recuperación de cuenta)
FRONTEND_URL=http://localhost:3000

# ────────────────────────────
# 🌍 Entorno de Ejecución
# ────────────────────────────
# Controla la visibilidad de la documentación Swagger (/docs).
# Opciones válidas: development | production
ENVIRONMENT=development
