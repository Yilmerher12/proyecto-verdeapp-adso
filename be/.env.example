# ==============================================================================
# ♻️ VerdeApp — Variables de Entorno del Backend (Plantilla)
# ==============================================================================
# INSTRUCCIONES:
#   1. Copiar: cp .env.example .env
#   2. Con Docker Compose no necesitas editar nada — funciona con estos valores.
#   3. NUNCA subas el .env real al repositorio (.gitignore ya lo protege).
# ==============================================================================

# ── Base de datos (PostgreSQL 17) ──────────────────────────────────────────────
# En Docker: host = nombre del servicio (verde_db), puerto interno = 5432
# En local sin Docker: cambiar @verde_db:5432 por @localhost:5433
DATABASE_URL=postgresql://verde_user:verde_password@verde_db:5432/verdeapp_db

# ── Seguridad JWT ──────────────────────────────────────────────────────────────
# ⚠️ Cambiar SECRET_KEY antes de cualquier despliegue real.
# Genera una nueva con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=9b8c2dfa8e34bc112a57f3de6c89fa0123de45fa67bc89de012345fa67bc89ab
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Correo (Mailpit — desarrollo local) ───────────────────────────────────────
# En Docker: SMTP_HOST = nombre del servicio (verde_mailpit)
# En local sin Docker: SMTP_HOST=localhost
# UI de Mailpit disponible en: http://localhost:8025
SMTP_HOST=verde_mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# ── Frontend ───────────────────────────────────────────────────────────────────
# Docker (modo demo/sustentación): http://localhost:3000
# Desarrollo local (pnpm dev):     http://localhost:5173
FRONTEND_URL=http://localhost:3000

# ── Entorno ────────────────────────────────────────────────────────────────────
# development → Swagger UI activo en http://localhost:8000/docs
# production  → Swagger desactivado
ENVIRONMENT=development